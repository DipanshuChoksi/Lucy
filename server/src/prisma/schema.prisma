generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String?
  googleId      String?  @unique
  githubToken   String?
  obsidianRepo  String?
  techStack     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}




