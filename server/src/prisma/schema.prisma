generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String?
  googleId      String?  @unique
  githubToken   String?
  obsidianRepo  String?
  techStack     String?
  storageProvider   String   @default("GITHUB")
  s3Bucket          String?
  s3Region          String?
  s3AccessKeyId     String?
  s3SecretAccessKey String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}




